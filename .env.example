# === Database ===
DATABASE_URL=postgresql://rmm_app:changeme@localhost:5432/rmmdb

# === Flask ===
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_SECRET_KEY=change-this-to-another-random-secret
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === API ===
API_HOST=0.0.0.0
API_PORT=5000
DASHBOARD_URL=http://localhost:8501
# For mobile/LAN access set to your PC's LAN IP, e.g. http://192.168.1.x:8501

# === Agent ===
# One-time org registration token — rotate after all agents registered
ORG_REGISTRATION_TOKEN=change-this-to-a-secure-random-token

# === Superadmin ===
# REQUIRED — API refuses to start without this. Min 10 characters.
SUPERADMIN_EMAIL=superadmin@rmm.local
SUPERADMIN_PASSWORD=change-this-strong-password

# === CORS ===
# Comma-separated list of allowed dashboard origins (no wildcards in production)
CORS_ORIGINS=http://localhost:8501

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=RMM System <your@email.com>

# === Dashboard ===
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:5000
